<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>QCM</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    </head>
    <body>
        <div class='container'>
            <h1>{{software_name}}</h1>
            <div class="alert alert-warning" role="alert">
                {% if alert == [] %}
                    Bienvenue sur notre site de quiz !
                {% else %}
                    {% for poster in alert %}
                        {{poster}}
                    {% endfor %}
                {% endif %}
            </div>
            
            <form action="" method="POST" class="card">
                <div class="card-header">
                    <h3>question N°{{Quiz.getId}}</h3>
                    <input type="hidden" name="id" value="{{Quiz.getId}}">
                </div>
                <div class="card-body">

                    <h5 class="card-title">{{Quiz.question}}</h5>
                    {% set index = 0 %}
                    {% for reponsePossible in Quiz.getOptions %}
                        {% set index = index + 1 %}
                        <input class="form-check-input" type="{{typeQuestion}}" name="response[]" id="{{index}}" value="{{reponsePossible}}">
                        <label class="form-check-label" for="{{index}}">
                            {{reponsePossible}}
                        </label>
                        <br>
                    {% endfor %}
                    <br>
                    <input type="submit" class="btn btn-primary" value="Valider"/>   
                </div> 
            </form>
        </div>
        
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
        <script>


        </script>
    </body>
</html>